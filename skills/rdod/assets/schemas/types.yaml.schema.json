{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RDOD types.yaml",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "domain_ref": { "type": "string" },
    "types": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "default_variant": { "type": "string" },
          "construction_defaults": {},
          "encoding": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "format": { "type": "string" },
                "rules": { "type": "string" }
              }
            }
          },
          "variants": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["name"],
              "properties": {
                "name": { "type": "string" },
                "description": { "type": "string" },
                "invariants": { "type": "array" },
                "fields": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["name", "type"],
                    "properties": {
                      "name": { "type": "string" },
                      "type": { "type": "string" },
                      "required": { "type": "boolean" },
                      "description": { "type": "string" },
                      "constraints": {}
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
