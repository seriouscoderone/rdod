{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RDOD protocols.yaml",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "domain_ref": { "type": "string" },
    "protocols": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "trigger": { "type": "string" },
          "timeout": { "type": "string" },
          "compensation": { "type": "string" },
          "invariants": { "type": "array", "items": { "type": "string" } },
          "failure_paths": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "step": { "type": ["integer", "string"] },
                "failure": { "type": "string" },
                "handling": { "type": "string" }
              }
            }
          },
          "participants": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "domain": { "type": "string" },
                "role": { "type": "string" }
              }
            }
          },
          "steps": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["seq", "action"],
              "properties": {
                "seq": { "type": "integer" },
                "domain": { "type": "string" },
                "action": { "type": "string" },
                "port": { "type": "string" },
                "input": {},
                "output": {},
                "depends_on": { "type": "array", "items": { "type": "integer" } },
                "preconditions": {
                  "type": "array",
                  "items": {
                    "oneOf": [
                      { "type": "string" },
                      {
                        "type": "object",
                        "additionalProperties": false,
                        "properties": {
                          "description": { "type": "string" },
                          "ref": { "type": "string" }
                        }
                      }
                    ]
                  }
                },
                "notes": { "type": "string" },
                "sub_steps": { "type": "array" },
                "on_failure": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                      "error": { "type": "string" },
                      "ref": { "type": "string" },
                      "action": { "type": "string" },
                      "compensation": { "type": "string" }
                    }
                  }
                }
              }
            }
          },
          "terminal_states": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "success": { "type": "string" },
              "failure": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
